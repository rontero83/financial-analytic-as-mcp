# Python / packaging
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# uv / virtual env
.venv/

# Test / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Build artifacts
dist/
build/
*.egg-info/

# Editor / OS noise
.DS_Store
*.swp

# PlantUML cache dir written by Docker container when HOME is unresolved
# (defense-in-depth — the `make diagrams` target sets -e HOME=/tmp to prevent this)
/?/

# Phase 1 runtime: task directories created by create_task at server runtime.
# Each task gets tasks/<task_id>/ with input.md, status.json, output.md,
# workspace/, logs/. Server-side runtime state — never committed.
# Negation keeps tasks/.gitignore tracked so the directory exists in the repo
# (its own .gitignore excludes everything inside).
/tasks/*
!/tasks/.gitignore

# Phase 2 runtime: dynamic catalog persistence (not present in Phase 1).
/.skills-index/

# Local-only project memory / planning workspace.
/.planning/
